generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String         @id @default(cuid())
  email     String         @unique
  name      String?
  avatar    String?
  role      String         @default("COUPLE")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  weddings  WeddingMember[]
}

model Wedding {
  id             String          @id @default(cuid())
  name           String
  date           DateTime
  budget         Float
  status         String          @default("PLANNING")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  pledges        Pledge[]
  budgetItems    BudgetCategory[]
  guests         Guest[]
  messages       Message[]
  notifications  Notification[]
  cards          Card[]
  checklistItems ChecklistItem[]
  members        WeddingMember[]
  timelineEvents TimelineEvent[]
  photos         Photo[]
}

model WeddingMember {
  id        String   @id @default(cuid())
  weddingId String
  userId    String
  role      String   @default("COUPLE")
  joinedAt  DateTime @default(now())
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([weddingId, userId])
}

model TimelineEvent {
  id          String   @id @default(cuid())
  weddingId   String
  time        String
  title       String
  description String   @default("")
  category    String   @default("ceremony")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Photo {
  id        String   @id @default(cuid())
  weddingId String
  src       String
  caption   String   @default("")
  category  String   @default("Inspiration")
  createdAt DateTime @default(now())
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Pledge {
  id              String   @id @default(cuid())
  weddingId       String
  contributorName String
  contributorEmail String
  amount          Float
  category        String
  status          String   @default("PENDING")
  message         String?
  createdAt       DateTime @default(now())
  wedding         Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  payments        Payment[]
}

model Payment {
  id              String   @id @default(cuid())
  pledgeId        String
  stripeSessionId String?
  amount          Float
  currency        String   @default("usd")
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  pledge          Pledge   @relation(fields: [pledgeId], references: [id], onDelete: Cascade)
}

model BudgetCategory {
  id             String   @id @default(cuid())
  weddingId      String
  name           String
  allocatedAmount Float
  spentAmount    Float    @default(0)
  createdAt      DateTime @default(now())
  wedding        Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Guest {
  id               String   @id @default(cuid())
  weddingId        String
  name             String
  email            String?
  phone            String?
  dietaryRestriction String?
  rsvpStatus       String   @default("PENDING")
  tableNumber      Int?
  plusOne          Boolean  @default(false)
  createdAt        DateTime @default(now())
  wedding          Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Vendor {
  id          String  @id @default(cuid())
  name        String
  category    String
  description String
  priceRange  String
  rating      Float   @default(0)
  contactEmail String?
  website     String?
}

model Message {
  id          String   @id @default(cuid())
  weddingId   String
  channelName String
  senderName  String
  content     String
  createdAt   DateTime @default(now())
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(cuid())
  weddingId   String
  title       String
  message     String
  type        String   @default("INFO")
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Card {
  id          String   @id @default(cuid())
  weddingId   String
  type        String
  title       String
  subtitle    String?
  designData  String   @default("{}")
  createdAt   DateTime @default(now())
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model ChecklistItem {
  id          String    @id @default(cuid())
  weddingId   String
  title       String
  category    String    @default("General")
  dueDate     DateTime?
  completed   Boolean   @default(false)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  wedding     Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}
